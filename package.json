{
  "name": "playwright-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-browser end-to-end test suite for saadm.dev, built with Playwright. Runs in GitHub Actions on every push, on a nightly schedule, and on demand.",
  "homepage": "https://saadm.dev/",
  "author": {
    "name": "Muhammad Saad",
    "email": "saad@saadm.dev",
    "url": "https://saadm.dev/"
  },
  "license": "MIT",
  "keywords": [
    "playwright",
    "end-to-end-testing",
    "e2e",
    "test-automation",
    "qa-automation",
    "cross-browser-testing",
    "github-actions",
    "typescript"
  ],
  "scripts": {
    "test": "playwright test",
    "test:site": "playwright test --project=chromium --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:api": "playwright test --project=api",
    "test:chromium": "playwright test --project=chromium",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://saadm.dev"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.10.0"
  }
}
